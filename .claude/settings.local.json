{
  "permissions": {
    "allow": [
      "Bash(python -c \":*)",
      "Bash(claude mcp:*)",
      "mcp__search-engine__tavily_search",
      "Bash(cd:*)",
      "Bash(cmd.exe /c build_exe.bat)",
